[run]
# Measure coverage for the application source only
source = app

# Exclude scripts, auto-generated paths, and untestable UI/infrastructure code
omit =
    app/scripts/*
    app/presentation/*
    app/config/*
    app/controllers/*
    app/core/db/backup.py
    app/core/db/migration.py
    app/core/db/reset.py
    app/core/db/restore.py
    */__pycache__/*
    */migrations/*

# Include branch coverage
branch = true

[report]
# Lines matching these patterns are excluded from the coverage report
exclude_lines =
    pragma: no cover
    def __repr__
    if TYPE_CHECKING:
    raise NotImplementedError
    if __name__ == .__main__.:
    pass

show_missing = true
skip_covered = false
precision = 2
