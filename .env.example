# =============================================================================
# PhotoShow — Environment Variables
# =============================================================================
# Copy this file to .env and fill in YOUR developer Cloudinary credentials.
# NEVER commit .env to version control — it is listed in .gitignore
#
# Get these credentials from your Cloudinary account dashboard:
# https://cloudinary.com/console

# Cloudinary Credentials (Your Developer Account)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Default Avatar Fallback
# Upload a default avatar image to YOUR Cloudinary account:
#   1. Go to Media Library in your Cloudinary dashboard
#   2. Upload an image to: photo-show > dev > profile_avatars folder
#   3. Copy the "Public ID" (e.g., photo-show/dev/profile_avatars/default_avatar)
#   4. Copy the "Secure URL" (https://res.cloudinary.com/...)
DEFAULT_AVATAR_PUBLIC_ID=
DEFAULT_AVATAR_URL=
