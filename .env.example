# =============================================================================
# PhotoShow — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in YOUR OWN developer credentials.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# Development Setup:
#   1. Each developer gets own Cloudinary account (free at https://cloudinary.com/)
#   2. Copy this file: cp .env.example .env
#   3. Fill in YOUR Cloudinary credentials (not shared credentials)
#   4. Test uploads go to YOUR account, not production

# =============================================================================

# ---------------------------------------------------------------------------
# Cloudinary Credentials (Developer Account)
# Get these from your Cloudinary dashboard 'API Key' section
# Your development uploads use ONLY your credentials, not production
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_dev_cloud_name
CLOUDINARY_API_KEY=your_dev_api_key
CLOUDINARY_API_SECRET=your_dev_api_secret

# ---------------------------------------------------------------------------
# Default Avatar Fallback
# Upload a default avatar image to YOUR Cloudinary account once:
#   1. Go to Media Library in Cloudinary dashboard
#   2. Upload an image to: photo-show > profile_avatars folder
#   3. Copy the "Public ID" (e.g., photo-show/profile_avatars/default_avatar)
#   4. Copy the "Secure URL" (https://res.cloudinary.com/...)
# ---------------------------------------------------------------------------
DEFAULT_AVATAR_PUBLIC_ID=
DEFAULT_AVATAR_URL=
